{
    "actorSpecification": 1,
    "fields": {
        "type": "object",
        "properties": {
            "type": { "type": "string", "description": "Item type discriminator: 'article' or 'event'" },
            "headline": { "type": "string", "description": "Article headline" },
            "title": { "type": "string", "description": "Event title" },
            "url": { "type": "string", "description": "URL of the article or event" },
            "text_content": { "type": "string", "description": "Full text content of the article" },
            "description": { "type": "string", "description": "Short description or summary" },
            "published_date": { "type": "string", "description": "Article published date (ISO)" },
            "source_name": { "type": "string", "description": "Name of the article source" },
            "source": { "type": "string", "description": "Event source: 'luma' or 'meetup.com'" },
            "start_date": { "type": "string", "description": "Event start date/time (ISO)" },
            "start_time": { "type": "string", "description": "Event start time" },
            "end_date": { "type": "string", "description": "Event end date/time (ISO)" },
            "end_time": { "type": "string", "description": "Event end time" },
            "timezone": { "type": "string", "description": "Event timezone (e.g. America/Chicago)" },
            "location": { "type": "string", "description": "Event full address" },
            "venue_name": { "type": "string", "description": "Event venue name" },
            "city": { "type": "string", "description": "Event city" },
            "state": { "type": "string", "description": "Event state" },
            "region": { "type": "string", "description": "Event region (e.g. Texas)" },
            "host_name": { "type": "string", "description": "Event host name" },
            "guest_count": { "type": "integer", "description": "Number of guests/RSVPs" },
            "is_free": { "type": "boolean", "description": "Whether the event is free" },
            "is_virtual": { "type": "boolean", "description": "Whether the event is virtual/online" },
            "scraped_at": { "type": "string", "description": "Timestamp when the item was scraped (ISO)" }
        }
    },
    "views": {
        "overview": {
            "title": "All Items",
            "description": "All scraped articles and events",
            "transformation": {
                "fields": [
                    "type", "headline", "title", "url", "description",
                    "published_date", "source_name", "source", "start_date",
                    "timezone", "location", "city", "region", "host_name",
                    "guest_count", "is_free", "scraped_at"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "type": { "label": "Type" },
                    "url": { "label": "URL", "format": "link" },
                    "guest_count": { "label": "Guests", "format": "number" },
                    "is_free": { "label": "Free", "format": "boolean" }
                }
            }
        },
        "articles": {
            "title": "Articles",
            "description": "Scraped articles from RSS feeds and additional URLs",
            "transformation": {
                "fields": [
                    "headline", "url", "text_content", "description",
                    "published_date", "source_name", "scraped_at"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "url": { "label": "URL", "format": "link" }
                }
            }
        },
        "events": {
            "title": "Events",
            "description": "Scraped events from Lu.ma and Meetup",
            "transformation": {
                "fields": [
                    "title", "url", "source", "start_date", "end_date",
                    "timezone", "location", "venue_name", "city", "region",
                    "host_name", "guest_count", "is_free", "is_virtual", "scraped_at"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "url": { "label": "URL", "format": "link" },
                    "guest_count": { "label": "Guests", "format": "number" },
                    "is_free": { "label": "Free", "format": "boolean" }
                }
            }
        }
    }
}
